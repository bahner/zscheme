; zscheme regression tests — TCO, named let, apply
;
; Run: zscheme tests/tco_named_let_apply.z
; All (assert …) forms must pass silently.

; ── named let ────────────────────────────────────────────────────────────────

(define (my-length lst)
  (let loop ((l lst) (n 0))
    (if (null? l) n (loop (cdr l) (+ n 1)))))

(assert (= (my-length '()) 0))
(assert (= (my-length '(a b c)) 3))

(define (my-reverse lst)
  (let loop ((l lst) (acc '()))
    (if (null? l) acc (loop (cdr l) (cons (car l) acc)))))

(assert (equal? (my-reverse '(1 2 3)) '(3 2 1)))

; named let with multiple returns
(define (sum-list lst)
  (let loop ((l lst) (acc 0))
    (if (null? l) acc (loop (cdr l) (+ acc (car l))))))

(assert (= (sum-list '(1 2 3 4 5)) 15))

; ── apply ─────────────────────────────────────────────────────────────────────

(assert (= (apply + '(1 2 3)) 6))
(assert (= (apply * '(2 3 4)) 24))
(assert (= (apply + 1 2 '(3 4)) 10))
(assert (equal? (apply list '(a b c)) '(a b c)))
(assert (= (apply max '(3 1 4 1 5 9 2 6)) 9))

; apply with user-defined lambda
(define (add3 a b c) (+ a b c))
(assert (= (apply add3 '(10 20 30)) 60))

; ── TCO — deep recursion must not stack-overflow ──────────────────────────────

; count down from 100000 — would overflow without TCO
(define (count-down n)
  (if (= n 0) "done" (count-down (- n 1))))

(assert (equal? (count-down 100000) "done"))

; mutual TCO via named let
(define (even? n)
  (let loop ((i n))
    (if (= i 0) #t (loop (- i 1)))))

(assert (equal? (even? 100000) #t))

; ── letrec TCO ───────────────────────────────────────────────────────────────

(define (factorial n)
  (letrec ((fact (lambda (i acc)
                   (if (= i 0) acc (fact (- i 1) (* acc i))))))
    (fact n 1)))

(assert (= (factorial 10) 3628800))

(display "All tests passed\n")
